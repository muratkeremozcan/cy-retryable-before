{
  "name": "cy-retryable-before",
  "version": "1.0.3",
  "description": "A Cypress plugin that allows a `before()`-like hook to rerun before retried tests.",
  "author": "Murat Ozcan",
  "license": "ISC",
  "main": "dist/retryable-before.js",
  "types": "dist/retryable-before.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "homepage": "https://github.com/muratkeremozcan/cy-retryable-before#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/muratkeremozcan/cy-retryable-before.git"
  },
  "bugs": {
    "url": "https://github.com/muratkeremozcan/cy-retryable-before/issues"
  },
  "keywords": [
    "cypress",
    "plugin",
    "retry",
    "before"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig-build.json",
    "cy:open-local": "cypress open --e2e --browser chrome --config-file cypress/config/local.config.ts",
    "cy:run-local": "cypress run --e2e --browser chrome --config-file cypress/config/local.config.ts",
    "mock:server": "npx mockoon-cli start --data ./mockoon/mock.json --port 3001",
    "prettier": "prettier --ignore-path .gitignore \"**/*.+(js|ts|json)\"",
    "fix:format": "npm run prettier -- --write",
    "validate": "npm-run-all --parallel typecheck lint test fix:format",
    "test": "jest --detectOpenHandles --verbose --silent --config jest.config.ts",
    "test:watch": "jest --watch --config jest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.jest.json",
    "lint": "eslint --ext=.js,.ts,.tsx --fix"
  },
  "devDependencies": {
    "@bahmutov/cy-api": "2.3.0",
    "@bahmutov/cypress-esbuild-preprocessor": "2.2.8",
    "@cypress/skip-test": "^2.6.1",
    "@esbuild-plugins/node-globals-polyfill": "0.2.3",
    "@esbuild-plugins/node-modules-polyfill": "0.2.2",
    "@faker-js/faker": "10.5.0",
    "@mockoon/cli": "9.7.0",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "24.13.2",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "cypress": "15.17.0",
    "cy-spok": "1.7.0",
    "cypress-data-session": "3.0.0",
    "cypress-map": "1.56.0",
    "cypress-recurse": "^1.35.3",
    "dotenv": "17.4.2",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-cypress": "3.6.0",
    "eslint-plugin-filenames": "1.3.2",
    "eslint-plugin-implicit-dependencies": "1.1.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-prettier": "5.5.6",
    "jest": "30.4.2",
    "lodash": "4.18.1",
    "npm-run-all2": "9.0.2",
    "prettier": "3.8.4",
    "ts-jest": "29.4.11",
    "tsx": "^4.19.1",
    "typescript": "6.0.3"
  }
}
